<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefreshLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="#F5F5F5">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/iv_escudo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="48dp"
                android:src="@drawable/escudo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_saludo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="HEY BARÇA"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/iv_escudo"
                app:layout_constraintStart_toEndOf="@id/iv_escudo"
                app:layout_constraintTop_toTopOf="@id/iv_escudo" />

            <ImageView
                android:id="@+id/iv_configuracion"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="48dp"
                android:layout_marginEnd="16dp"
                android:src="@android:drawable/ic_menu_manage"
                app:tint="@color/black"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardProximoPartido"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:layout_constraintTop_toBottomOf="@id/iv_escudo">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <View
                        android:id="@+id/fondo_top"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:background="@drawable/bg_mitad_blaugrana"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:id="@+id/ivLocalCrest"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_marginTop="24dp"
                        android:src="@drawable/escudo"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/contenedor_central"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:id="@+id/ivVisitanteCrest"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_marginTop="24dp"
                        android:src="@drawable/escudo"
                        app:layout_constraintStart_toEndOf="@id/contenedor_central"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvLocalNombre"
                        android:layout_width="110dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toBottomOf="@id/ivLocalCrest"
                        app:layout_constraintStart_toStartOf="@id/ivLocalCrest"
                        app:layout_constraintEnd_toEndOf="@id/ivLocalCrest"
                        tools:text="FC Barcelona" />

                    <TextView
                        android:id="@+id/tvVisitanteNombre"
                        android:layout_width="110dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toBottomOf="@id/ivVisitanteCrest"
                        app:layout_constraintStart_toStartOf="@id/ivVisitanteCrest"
                        app:layout_constraintEnd_toEndOf="@id/ivVisitanteCrest"
                        tools:text="Real Madrid" />

                    <FrameLayout
                        android:id="@+id/contenedor_central"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="32dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <LinearLayout
                            android:id="@+id/layout_contador"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <TextView android:id="@+id/tv_dias" style="@style/Widget.AppCompat.TextView" android:layout_width="34dp" android:layout_height="34dp" android:gravity="center" android:background="@drawable/bg_caja_contador" android:text="00" android:textColor="#FFFFFF" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=":" android:textColor="#FFFFFF" android:textSize="22sp" android:layout_marginHorizontal="3dp"/>
                            <TextView android:id="@+id/tv_horas" android:layout_width="34dp" android:layout_height="34dp" android:gravity="center" android:background="@drawable/bg_caja_contador" android:text="00" android:textColor="#FFFFFF" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=":" android:textColor="#FFFFFF" android:textSize="22sp" android:layout_marginHorizontal="3dp"/>
                            <TextView android:id="@+id/tv_minutos" android:layout_width="34dp" android:layout_height="34dp" android:gravity="center" android:background="@drawable/bg_caja_contador" android:text="00" android:textColor="#FFFFFF" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=":" android:textColor="#FFFFFF" android:textSize="22sp" android:layout_marginHorizontal="3dp"/>
                            <TextView android:id="@+id/tv_segundos" android:layout_width="34dp" android:layout_height="34dp" android:gravity="center" android:background="@drawable/bg_caja_contador" android:text="00" android:textColor="#FFFFFF" android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layout_marcador"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <TextView
                                android:id="@+id/tv_estado_partido"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="EN VIVO"
                                android:textColor="#FFFF00"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_resultado"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 - 0"
                                android:textColor="#FFFFFF"
                                android:textSize="38sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_goleadores"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:textColor="#FFFFFF" />
                        </LinearLayout>
                    </FrameLayout>

                    <LinearLayout
                        android:id="@+id/footer_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#FFFFFF"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        app:layout_constraintTop_toBottomOf="@id/fondo_top">

                        <TextView
                            android:id="@+id/tv_dia_numero"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00"
                            android:textColor="#000000"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_mes_texto"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="MES"
                            android:textColor="#000000"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_hora_numero"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:text="00:00"
                            android:textColor="#000000"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/card_seccion_plantilla"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:layout_constraintTop_toBottomOf="@id/cardProximoPartido">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_tarjeta_blanca">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Plantilla Barcelona"
                        android:textColor="@color/black"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_view"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tv_wallpapers_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Top Wallpapers"
                android:textColor="@color/black"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/card_seccion_plantilla"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:columnCount="2"
                app:layout_constraintTop_toBottomOf="@id/tv_wallpapers_title"
                app:layout_constraintBottom_toBottomOf="parent">

                <androidx.cardview.widget.CardView android:id="@+id/card_futbolistas" android:layout_width="0dp" android:layout_height="180dp" android:layout_columnWeight="1" android:layout_margin="8dp" app:cardCornerRadius="12dp">
                    <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerInside" android:src="@drawable/futbolistas"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="bottom" android:gravity="center" android:padding="8dp" android:background="#99000000" android:text="Futbolistas" android:textColor="#FFFFFF" android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView android:id="@+id/card_estadio" android:layout_width="0dp" android:layout_height="180dp" android:layout_columnWeight="1" android:layout_margin="8dp" app:cardCornerRadius="12dp">
                    <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerInside" android:src="@drawable/estadio"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="bottom" android:gravity="center" android:padding="8dp" android:background="#99000000" android:text="Estadio" android:textColor="#FFFFFF" android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView android:id="@+id/card_camisetas" android:layout_width="0dp" android:layout_height="180dp" android:layout_columnWeight="1" android:layout_margin="8dp" app:cardCornerRadius="12dp">
                    <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerInside" android:src="@drawable/camiseta"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="bottom" android:gravity="center" android:padding="8dp" android:background="#99000000" android:text="Camisetas" android:textColor="#FFFFFF" android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView android:id="@+id/card_leyendas" android:layout_width="0dp" android:layout_height="180dp" android:layout_columnWeight="1" android:layout_margin="8dp" app:cardCornerRadius="12dp">
                    <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerInside" android:src="@drawable/leyendas"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="bottom" android:gravity="center" android:padding="8dp" android:background="#99000000" android:text="Leyendas" android:textColor="#FFFFFF" android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>

            </GridLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>